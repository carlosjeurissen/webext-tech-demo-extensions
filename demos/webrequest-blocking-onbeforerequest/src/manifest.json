    "service_worker": "background.js"
  },
  "action": {
    "default_area": "navbar"
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking"
  ],
  "host_permissions": [
    "https://www.example.com/webext-demos/webrequest-blocking-onbeforerequest/*"
  ]
}
