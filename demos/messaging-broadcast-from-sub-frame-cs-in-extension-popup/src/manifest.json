{
  "manifest_version": 3,
  "name": "messaging-broadcast-from-sub-frame-cs-in-extension-popup",
  "description": "messaging-broadcast-from-sub-frame-cs-in-extension-popup",
  "homepage_url": "https://jeurissen.co/webext-demos/messaging-broadcast-from-sub-frame-cs-in-extension-popup",
  "author": "Carlos Jeurissen",
  "version": "0.0.2",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://www.example.com/*"
  ],
  "content_scripts": [{
    "all_frames": true,
    "matches": ["https://www.example.com/*"],
    "js": ["content-script.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_area": "navbar",
    "default_popup": "popup.html"
  }
}
