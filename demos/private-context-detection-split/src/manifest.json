{
  "manifest_version": 3,
  "name": "private-context-detection-split",
  "description": "private-context-detection-split",
  "homepage_url": "https://jeurissen.co/webext-demos/private-context-detection-split",
  "author": "Carlos Jeurissen",
  "version": "0.0.2",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "action": {
    "default_area": "navbar",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "permissions": ["activeTab"],
  "host_permissions": ["https://www.example.com/*"],
  "content_scripts": [{
    "matches": ["https://www.example.com/webext-demos/private-context-detection-split"],
    "js": ["main.js"],
    "run_at": "document_idle"
  }],
  "web_accessible_resources": [{
    "matches": ["https://www.example.com/*"],
    "resources": ["embed.html"]
  }],
  "incognito": "split"
}
