{
  "manifest_version": 3,
  "name": "dnr-redirect-to-extension-path",
  "description": "dnr-redirect-to-extension-path",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "permissions": [
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://*.example.com/*",
    "https://*.example.org/*",
    "<all_urls>"
  ]
}
