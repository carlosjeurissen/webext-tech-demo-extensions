{
  "manifest_version": 3,
  "name": "dnr-in-extension-page",
  "description": "dnr-in-extension-page",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "action": {
    "default_area": "navbar"
  },
  "options_page": "main.html",
  "options_ui": {
    "page": "main.html",
    "open_in_tab": true
  },
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "webRequest"
  ],
  "host_permissions": [
    "https://httpbin.org/anything/dnr-in-extension-page/*"
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset",
      "enabled": true,
      "path": "rules.json"
    }]
  }
}
