{
  "manifest_version": 2,
  "name": "action-browser-popup-methods",
  "description": "action-browser-popup-methods",
  "homepage_url": "https://jeurissen.co/webext-demos/action-browser-popup-methods",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "browser_action": {
    "default_area": "navbar",
    "default_popup": "popup.html"
  },
  "options_page": "main.html",
  "options_ui": {
    "page": "main.html",
    "open_in_tab": true
  }
}
