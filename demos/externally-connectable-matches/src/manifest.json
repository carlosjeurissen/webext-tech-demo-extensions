{
  "manifest_version": 3,
  "name": "externally-connectable-matches",
  "description": "externally-connectable-matches",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "action": {
    "default_area": "navbar"
  },
  "permissions": ["scripting"],
  "host_permissions": ["https://www.example.com/*"],
  "externally_connectable": {
    "matches": ["https://www.example.com/*"]
  }
}
