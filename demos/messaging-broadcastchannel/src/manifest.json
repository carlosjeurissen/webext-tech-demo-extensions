{
  "manifest_version": 3,
  "name": "messaging-broadcastchannel",
  "description": "messaging-broadcastchannel",
  "version": "0.0.1",
  "permissions": ["sidePanel"],
  "host_permissions": ["https://example.com/*"],
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "action": {
    "default_area": "navbar",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "sidebar_action": {
    "open_at_install": true,
    "default_panel": "sidebar.html"
  },
  "content_scripts": [
    {
      "matches": ["https://example.com/*"],
      "js": ["cs-isolated.js"],
      "all_frames": true,
      "world": "ISOLATED"
    },
    {
      "matches": ["https://example.com/*"],
      "css": ["cs-main.css"],
      "js": ["cs-main.js"],
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
