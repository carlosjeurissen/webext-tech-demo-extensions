{
  "manifest_version": 3,
  "name": "dnr-redirect-static-session",
  "description": "dnr-redirect-static-session",
  "homepage_url": "https://jeurissen.co/webext-demos/dnr-redirect-static-session",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "action": {
    "default_area": "navbar"
  },
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "https://www.example.nl/*",
    "https://www.example.org/*",
    "https://www.example.com/*",
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset",
      "enabled": true,
      "path": "ruleset.json"
    }]
  }
}
