{
  "manifest_version": 3,
  "name": "content-scripts-query-matches",
  "description": "content-scripts-query-matches",
  "homepage_url": "https://jeurissen.co/webext-demos/content-scripts-query-matches",
  "author": "Carlos Jeurissen",
  "version": "0.0.2",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "css": ["content-script.css"],
    "matches": ["https://example.com/*query*"]
  }]
}
