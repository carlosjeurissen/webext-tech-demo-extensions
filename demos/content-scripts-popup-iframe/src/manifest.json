{
  "manifest_version": 3,
  "name": "content-scripts-popup-iframe",
  "description": "content-scripts-popup-iframe",
  "homepage_url": "https://jeurissen.co/webext-demos/content-scripts-popup-iframe",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "host_permissions": [
    "https://*.example.com/*"
  ],
  "action": {
    "default_area": "navbar",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "js": ["content-script.js"],
    "matches": ["https://*.example.com/*"],
    "all_frames": true
  }]
}
