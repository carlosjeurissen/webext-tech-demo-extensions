{
  "manifest_version": 3,
  "name": "options-open-options-page",
  "description": "options-open-options-page",
  "homepage_url": "https://jeurissen.co/webext-demos/options-open-options-page",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "action": {
    "default_area": "navbar"
  },
  "options_page": "options.html",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
