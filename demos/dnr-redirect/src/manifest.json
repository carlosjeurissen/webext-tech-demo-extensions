{
  "manifest_version": 3,
  "name": "dnr-redirect",
  "description": "dnr-redirect",
  "version": "1.0",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://www.example.com/*"
  ],
  "action": {
    "default_area": "navbar"
  }
}
