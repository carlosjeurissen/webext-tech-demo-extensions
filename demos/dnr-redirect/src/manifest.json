{
  "manifest_version": 3,
  "name": "dnr-redirect",
  "description": "dnr-redirect",
  "homepage_url": "https://jeurissen.co/webext-demos/dnr-redirect",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://www.example.com/*"
  ],
  "action": {
    "default_area": "navbar"
  }
}
