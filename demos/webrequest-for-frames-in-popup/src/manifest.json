{
  "manifest_version": 3,
  "name": "webrequest-for-frames-in-popup",
  "description": "webrequest-for-frames-in-popup",
  "homepage_url": "https://jeurissen.co/webext-demos/webrequest-for-frames-in-popup",
  "author": "Carlos Jeurissen",
  "version": "5.0",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "action": {
    "default_area": "navbar",
    "default_popup": "popup.html"
  },
  "permissions": [
    "webRequest"
  ],
  "host_permissions": [
    "https://*.example.org/*",
    "https://*.example.com/*",
    "https://example.org/*",
    "https://example.com/*"
  ]
}
