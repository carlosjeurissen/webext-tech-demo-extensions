{
  "manifest_version": 3,
  "name": "messaging-top-frame-cs-to-extension-sub-frame",
  "description": "messaging-top-frame-cs-to-extension-sub-frame",
  "homepage_url": "https://jeurissen.co/webext-demos/messaging-top-frame-cs-to-extension-sub-frame",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://*.example.com/*"
  ],
  "content_scripts": [{
    "matches": ["https://*.example.com/*"],
    "js": ["content-script.js"],
    "run_at": "document_idle"
  }],
  "web_accessible_resources": [
    {
      "resources": [ "/frame.html" ],
      "matches": [ "https://*.example.com/*" ]
    }
  ]
}
