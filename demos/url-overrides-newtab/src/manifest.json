{
  "manifest_version": 3,
  "name": "url-overrides-newtab",
  "description": "url-overrides-newtab",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "/icon.png",
    "32": "/icon.png",
    "48": "/icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "options_page": "/newtab.html?env=options",
  "options_ui": {
    "page": "/newtab.html?env=options",
    "open_in_tab": true
  },
  "chrome_url_overrides": {
    "newtab": "/newtab.html?env=newtab"
  }
}
