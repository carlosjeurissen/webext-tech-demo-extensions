{
  "manifest_version": 3,
  "name": "content-script-iframe-csp-bypass",
  "description": "content-script-iframe-csp-bypass",
  "homepage_url": "https://jeurissen.co/webext-demos/content-script-iframe-csp-bypass",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": [ "<all_urls>" ],
    "js": [ "content-script.js" ],
    "run_at": "document_end"
  }],
  "host_permissions": [
    "<all_urls>"
  ]
}
