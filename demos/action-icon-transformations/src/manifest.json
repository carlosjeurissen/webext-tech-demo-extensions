{
  "manifest_version": 3,
  "name": "action-icon-transformations",
  "description": "action-icon-transformations",
  "homepage_url": "https://jeurissen.co/webext-demos/action-icon-transformations",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "unicolor-16.png",
    "19": "unicolor-19.png",
    "32": "unicolor-32.png",
    "38": "unicolor-38.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "action": {
    "default_area": "navbar",
    "default_icon": {
      "16": "unicolor-16.png",
      "19": "unicolor-19.png",
      "32": "unicolor-32.png",
      "38": "unicolor-38.png"
    }
  },
  "host_permissions": [
    "https://www.example.com/"
  ],
  "permissions": [
    "storage"
  ]
}
