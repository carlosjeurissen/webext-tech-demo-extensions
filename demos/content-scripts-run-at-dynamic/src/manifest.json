{
  "manifest_version": 3,
  "name": "content-scripts-run-at-dynamic",
  "description": "content-scripts-run-at-dynamic",
  "homepage_url": "https://jeurissen.co/webext-demos/content-scripts-run-at-dynamic",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "action": {
    "default_area": "navbar"
  },
  "permissions": ["scripting"],
  "host_permissions": ["https://www.example.com/"]
}
