{
    "integer": {
        "message": "$COUNT$ apples",
        "placeholders": {
            "count": {
                "content": "$1",
                "example": "15"
            }
        }
    },
    "consequent": {
        "message": "$PLACEHOLDER_1$ $PLACEHOLDER_2$$PLACEHOLDER_3$",
        "placeholders": {
            "placeholder_1": {
                "content": "$1"
            },
            "placeholder_2": {
                "content": "$2"
            },
            "placeholder_3": {
                "content": "$3"
            }
        }
    },
    "innerspaces": {
        "message": "$PREFIX$ace$SUFFIX$",
        "placeholders": {
            "prefix": {
                "content": "$1"
            },
            "suffix": {
                "content": "$2"
            }
        }
    },
    "whitespacecollapse": {
        "message": " $ONE$ middle $TWO$ ",
        "placeholders": {
            "one": {
                "content": "$1"
            },
            "two": {
                "content": "$2"
            }
        }
    },
    "incomplete": {
        "message": "1: $PLACEHOLDER_1$ 2: $PLACEHOLDER_2$ 3: $PLACEHOLDER_3$",
        "placeholders": {
            "placeholder_1": {
                "content": "$1"
            },
            "placeholder_2": {
                "content": "$2"
            },
            "placeholder_3": {
                "content": "$3"
            }
        }
    }
}
