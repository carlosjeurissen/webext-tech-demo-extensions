{
  "manifest_version": 3,
  "name": "context-menus-menu-types-product",
  "description": "context-menus-menu-types-product",
  "homepage_url": "https://jeurissen.co/webext-demos/context-menus-menu-types-product",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "permissions": [
    "activeTab",
    "contextMenus",
    "menus"
  ],
  "action": {
    "default_area": "navbar"
  }
}
