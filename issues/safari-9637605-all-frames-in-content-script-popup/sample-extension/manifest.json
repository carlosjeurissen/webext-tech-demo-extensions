{
  "manifest_version": 3,
  "name": "9637605-all_frames contentscript popup issue",
  "description": "9637605-all_frames contentscript popup issue",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "action": {
    "default_area": "navbar",
    "default_popup": "popup.html"
  },
  "permissions": [
    "<all_urls>"
  ],
  "content_scripts": [{
    "all_frames": true,
    "matches": ["<all_urls>"],
    "js": ["content-script.js"]
  }]
}
