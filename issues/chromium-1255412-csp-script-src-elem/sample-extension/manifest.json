{
  "manifest_version": 3,
  "name": "chrome-csp-script-src-elem",
  "description": "chrome-csp-script-src-elem",
  "version": "0.0.1",
  "content_security_policy": {
    "extension_pages": "default-src 'none'; script-src-elem 'self' https:"
  },
  "action": {
    "default_area": "navbar",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  }
}
