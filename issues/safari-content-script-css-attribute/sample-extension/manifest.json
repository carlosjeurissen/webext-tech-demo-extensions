{
  "manifest_version": 3,
  "name": "safari-content-script-css-attribute",
  "description": "safari-content-script-css-attribute",
  "author": "Carlos Jeurissen",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "css": [ "content-script.css" ],
    "js": [ "content-script.js" ],
    "matches": [ "https://example.com/*" ]
  }]
}
