{
  "manifest_version": 2,
  "name": "safari-content-script-css-attribute",
  "description": "safari-content-script-css-attribute",
  "version": "0.0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png"
  },
  "content_scripts": [{
    "css": [ "content-script.css" ],
    "js": [ "content-script.js" ],
    "matches": [ "https://example.com/*" ]
  }],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  }
}
